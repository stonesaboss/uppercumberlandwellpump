# Upper Cumberland Well Pump — environment variables
# Copy to .env for local development. Never commit real values.

# Canonical production site URL (no trailing slash)
PUBLIC_SITE_URL=https://uppercumberlandwellpump.com

# Cloudflare Turnstile (https://dash.cloudflare.com -> Turnstile)
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Lead delivery — configure at least one for production
LEAD_WEBHOOK_URL=
LEAD_WEBHOOK_SECRET=
FORM_RECIPIENT_EMAIL=
EMAIL_API_KEY=

# Analytics (optional — nothing loads when empty)
ANALYTICS_ID=
TAG_MANAGER_ID=

# Optional storage toggles ("true" to enable; bindings must exist)
ENABLE_D1_STORAGE=
ENABLE_R2_UPLOADS=
