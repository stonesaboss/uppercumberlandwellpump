---
import PhoneLink from "./PhoneLink.astro";

interface Props {
  heading?: string;
  copy?: string;
  primaryLabel?: string;
  primaryHref?: string;
}
const {
  heading = "Request Help With Your Well Pump or Water System",
  copy = "Tell us whether the property has no water, low pressure, pump cycling, pressure-tank problems or another private-well concern.",
  primaryLabel = "Request Well-Pump Service",
  primaryHref = "/request-service/",
} = Astro.props;
---

<section class="section section--navy cta-band">
  <div class="container text-center">
    <h2>{heading}</h2>
    <p class="cta-band__copy">{copy}</p>
    <div class="cta-band__actions">
      <a href={primaryHref} class="btn btn--primary" data-event="request_service_cta">{primaryLabel}</a>
      <PhoneLink class="btn btn--outline-light" prefix="Call " eventLabel="cta_phone_click" />
    </div>
  </div>
</section>

<style>
  .cta-band {
    background-image:
      linear-gradient(rgba(7, 31, 58, 0.88), rgba(12, 49, 88, 0.92)),
      url("/images/other/well-service-ridge-background.webp");
    background-size: cover;
    background-position: center;
  }
  .cta-band__copy {
    max-width: 42rem;
    margin-inline: auto;
  }
  .cta-band__actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }
</style>
