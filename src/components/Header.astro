---
import { PRIMARY_NAV } from "../data/nav";
import PhoneLink from "./PhoneLink.astro";
---

<a class="skip-link" href="#main-content">Skip to main content</a>

<div class="utility-bar">
  <div class="container utility-bar__inner">
    <p class="utility-bar__left">
      <span aria-hidden="true">📍</span> Serving Cookeville, Crossville, Livingston &amp; Upper
      Cumberland
    </p>
    <p class="utility-bar__right">
      <span class="utility-bar__question">Having a Well-System Problem?</span>
      <PhoneLink class="utility-bar__phone" prefix="Call " eventLabel="header_phone_click" />
    </p>
  </div>
</div>

<header class="site-header" data-sticky-header>
  <div class="container site-header__inner">
    <a href="/" class="brand" aria-label="Upper Cumberland Well Pump — home">
      <img
        src="/logos/ucwp-shield-200.png"
        alt=""
        width="64"
        height="64"
        class="brand__shield"
      />
      <span class="brand__text">
        <span class="brand__name">Upper Cumberland <strong>Well Pump</strong></span>
        <span class="brand__tag">Well Pump Repair, Replacement &amp; Water Well Services</span>
      </span>
    </a>

    <button
      class="nav-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="primary-nav"
      data-nav-toggle
    >
      <span class="nav-toggle__bars" aria-hidden="true"><span></span><span></span><span></span></span>
      <span class="nav-toggle__label">Menu</span>
    </button>

    <nav id="primary-nav" class="primary-nav" aria-label="Primary" data-primary-nav>
      <ul class="primary-nav__list">
        {
          PRIMARY_NAV.map((item) =>
            item.children ? (
              <li class="primary-nav__item has-dropdown">
                <button
                  type="button"
                  class="primary-nav__link primary-nav__dropdown-btn"
                  aria-expanded="false"
                  data-dropdown-toggle
                >
                  {item.label}
                  <span class="caret" aria-hidden="true">▾</span>
                </button>
                <ul class="dropdown" data-dropdown>
                  {item.children.map((child) => (
                    <li>
                      <a href={child.href}>{child.label}</a>
                    </li>
                  ))}
                </ul>
              </li>
            ) : (
              <li class="primary-nav__item">
                <a class="primary-nav__link" href={item.href}>
                  {item.label}
                </a>
              </li>
            ),
          )
        }
        <li class="primary-nav__item primary-nav__cta-item">
          <a class="btn btn--primary primary-nav__cta" href="/request-service/" data-event="request_service_cta">
            Request Well-Pump Service
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .utility-bar {
    background: var(--navy-deep);
    color: var(--white);
    font-size: 0.85rem;
  }
  .utility-bar__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    min-height: 40px;
    flex-wrap: wrap;
    padding-block: 0.35rem;
  }
  .utility-bar p {
    margin: 0;
  }
  .utility-bar__question {
    color: #b9cbdd;
    margin-right: 0.6rem;
  }
  .utility-bar :global(.utility-bar__phone) {
    color: var(--white);
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .site-header {
    background: var(--white);
    border-bottom: 1px solid var(--gray-border);
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 1px 6px rgba(7, 31, 58, 0.07);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 76px;
    max-width: 1380px; /* header may run wider than page sections so the nav fits one line */
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
    padding-block: 0.5rem;
  }
  .brand__shield {
    width: 56px;
    height: 56px;
    object-fit: contain;
  }
  .brand__text {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }
  .brand__name {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    text-transform: uppercase;
    color: var(--navy);
    letter-spacing: 0.02em;
    white-space: nowrap;
  }
  .brand__name strong {
    color: var(--blue);
  }
  .brand__tag {
    font-size: 0.68rem;
    color: #4a5a68;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .nav-toggle {
    display: none;
    background: none;
    border: 2px solid var(--navy);
    border-radius: var(--radius-sm);
    padding: 0.5rem 0.8rem;
    cursor: pointer;
    align-items: center;
    gap: 0.5rem;
    min-height: 48px;
    color: var(--navy);
    font-weight: 700;
  }
  .nav-toggle__bars {
    display: inline-flex;
    flex-direction: column;
    gap: 4px;
  }
  .nav-toggle__bars span {
    width: 20px;
    height: 2.5px;
    background: var(--navy);
    border-radius: 2px;
  }

  .primary-nav__list {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.1rem;
    margin: 0;
    padding: 0;
    flex-wrap: nowrap;
  }
  .primary-nav__link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.6rem 0.4rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--charcoal);
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-body);
    border-radius: var(--radius-sm);
    white-space: nowrap;
  }
  .primary-nav__link:hover {
    color: var(--blue);
    background: var(--gray-light);
  }
  .caret {
    font-size: 0.7rem;
  }

  .has-dropdown {
    position: relative;
  }
  .dropdown {
    list-style: none;
    margin: 0;
    padding: 0.5rem 0;
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 250px;
    background: var(--white);
    border: 1px solid var(--gray-border);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-raised);
    display: none;
    z-index: 110;
  }
  .dropdown a {
    display: block;
    padding: 0.55rem 1.1rem;
    text-decoration: none;
    color: var(--charcoal);
    font-size: 0.92rem;
  }
  .dropdown a:hover {
    background: var(--blue-light);
    color: var(--navy);
  }
  .has-dropdown[data-open] .dropdown {
    display: block;
  }

  .primary-nav__cta {
    font-size: 0.75rem;
    letter-spacing: 0.01em;
    padding: 0.55rem 0.75rem;
    margin-left: 0.3rem;
    white-space: nowrap;
    min-height: 42px;
  }

  /* Between the mobile breakpoint and full-width desktop, show the shield
     only so the whole nav fits on one line. */
  @media (min-width: 1181px) and (max-width: 1419px) {
    .brand__text {
      display: none;
    }
  }

  @media (max-width: 1180px) {
    .nav-toggle {
      display: inline-flex;
    }
    .primary-nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--white);
      border-bottom: 1px solid var(--gray-border);
      box-shadow: var(--shadow-raised);
      max-height: calc(100vh - 130px);
      overflow-y: auto;
    }
    .primary-nav[data-open] {
      display: block;
    }
    .primary-nav__list {
      flex-direction: column;
      align-items: stretch;
      padding: 0.75rem 1.25rem 1.25rem;
      gap: 0;
    }
    .primary-nav__link {
      width: 100%;
      justify-content: space-between;
      padding: 0.85rem 0.5rem;
      font-size: 1.05rem;
      border-bottom: 1px solid var(--gray-light);
      border-radius: 0;
    }
    .dropdown {
      position: static;
      box-shadow: none;
      border: none;
      border-left: 3px solid var(--blue-light);
      margin: 0 0 0.5rem 0.75rem;
      min-width: 0;
    }
    .dropdown a {
      padding: 0.7rem 0.9rem;
      font-size: 1rem;
    }
    .primary-nav__cta-item {
      margin-top: 1rem;
    }
    .primary-nav__cta {
      width: 100%;
      margin-left: 0;
    }
  }
</style>

<script>
  // Mobile nav toggle
  const toggle = document.querySelector<HTMLButtonElement>("[data-nav-toggle]");
  const nav = document.querySelector<HTMLElement>("[data-primary-nav]");
  toggle?.addEventListener("click", () => {
    const open = nav?.hasAttribute("data-open");
    if (open) {
      nav?.removeAttribute("data-open");
      toggle.setAttribute("aria-expanded", "false");
    } else {
      nav?.setAttribute("data-open", "");
      toggle.setAttribute("aria-expanded", "true");
    }
  });

  // Dropdown menus (click + keyboard accessible)
  const items = document.querySelectorAll<HTMLElement>(".has-dropdown");
  items.forEach((item) => {
    const btn = item.querySelector<HTMLButtonElement>("[data-dropdown-toggle]");
    btn?.addEventListener("click", (e) => {
      e.stopPropagation();
      const isOpen = item.hasAttribute("data-open");
      items.forEach((other) => {
        other.removeAttribute("data-open");
        other
          .querySelector("[data-dropdown-toggle]")
          ?.setAttribute("aria-expanded", "false");
      });
      if (!isOpen) {
        item.setAttribute("data-open", "");
        btn.setAttribute("aria-expanded", "true");
      }
    });
  });

  document.addEventListener("click", (e) => {
    if (!(e.target as HTMLElement).closest(".has-dropdown")) {
      items.forEach((item) => {
        item.removeAttribute("data-open");
        item
          .querySelector("[data-dropdown-toggle]")
          ?.setAttribute("aria-expanded", "false");
      });
    }
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      items.forEach((item) => {
        item.removeAttribute("data-open");
        item
          .querySelector("[data-dropdown-toggle]")
          ?.setAttribute("aria-expanded", "false");
      });
      nav?.removeAttribute("data-open");
      toggle?.setAttribute("aria-expanded", "false");
    }
  });
</script>
