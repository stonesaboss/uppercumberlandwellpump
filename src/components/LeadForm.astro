---
/**
 * Diagnostic lead form.
 * variant="hero"  — compact version for the homepage hero.
 * variant="full"  — complete diagnostic form (request-service page & service pages).
 * Posts multipart FormData to /api/lead (Cloudflare Pages Function).
 */
import {
  PROPERTY_TYPES,
  SERVICES_NEEDED,
  WATER_SITUATIONS,
  PROBLEM_STARTED,
  URGENCY_LEVELS,
  CONTACT_TIMES,
  PUMP_TYPES,
  PUMP_RUNNING,
  BREAKER_STATUS,
} from "../data/formOptions";
import { SITE, CONSENT_TEXT, FORM_DISCLAIMER } from "../data/site";

interface Props {
  variant?: "hero" | "full";
  heading?: string;
  description?: string;
  defaultService?: string;
  id?: string;
}

const {
  variant = "full",
  heading = "Request Well-Pump Service",
  description = "Tell us what is happening with the property's water system.",
  defaultService = "",
  id = variant === "hero" ? "hero-lead-form" : "lead-form",
} = Astro.props;

const isFull = variant === "full";
---

<div class={`lead-form-card lead-form-card--${variant}`}>
  <h3 class="lead-form-card__heading" id={`${id}-heading`}>{heading}</h3>
  <p class="lead-form-card__desc">{description}</p>

  <form
    method="post"
    action="/api/lead"
    enctype="multipart/form-data"
    novalidate
    data-lead-form
    id={id}
    aria-labelledby={`${id}-heading`}
  >
    <div class="form-status" role="status" aria-live="polite" data-form-status></div>

    <div class="form-field">
      <label for={`${id}-name`}>Full Name <span class="required-mark" aria-hidden="true">*</span></label>
      <input type="text" id={`${id}-name`} name="full_name" autocomplete="name" required maxlength="120" aria-describedby={`${id}-name-err`} />
      <p class="field-error" id={`${id}-name-err`}>Please enter your full name.</p>
    </div>

    <div class="form-field">
      <label for={`${id}-phone`}>Phone Number <span class="required-mark" aria-hidden="true">*</span></label>
      <input type="tel" id={`${id}-phone`} name="phone" autocomplete="tel" required maxlength="30" aria-describedby={`${id}-phone-err`} />
      <p class="field-error" id={`${id}-phone-err`}>Please enter a valid phone number.</p>
    </div>

    <div class="form-field">
      <label for={`${id}-email`}>Email Address <span class="required-mark" aria-hidden="true">*</span></label>
      <input type="email" id={`${id}-email`} name="email" autocomplete="email" required maxlength="200" aria-describedby={`${id}-email-err`} />
      <p class="field-error" id={`${id}-email-err`}>Please enter a valid email address.</p>
    </div>

    <div class="form-field">
      <label for={`${id}-city`}>City or County <span class="required-mark" aria-hidden="true">*</span></label>
      <input
        type="text"
        id={`${id}-city`}
        name="city_or_county"
        required
        maxlength="120"
        placeholder="e.g., Cookeville, Putnam County"
        aria-describedby={`${id}-city-err`}
      />
      <p class="field-error" id={`${id}-city-err`}>Please tell us the city or county.</p>
    </div>

    {isFull && (
      <div class="form-field">
        <label for={`${id}-property-type`}>Property Type <span class="required-mark" aria-hidden="true">*</span></label>
        <select id={`${id}-property-type`} name="property_type" required aria-describedby={`${id}-property-type-err`}>
          <option value="">Select property type</option>
          {PROPERTY_TYPES.map((o) => (
            <option value={o}>{o}</option>
          ))}
        </select>
        <p class="field-error" id={`${id}-property-type-err`}>Please select a property type.</p>
      </div>
    )}

    <div class="form-field">
      <label for={`${id}-service`}>Service Needed <span class="required-mark" aria-hidden="true">*</span></label>
      <select id={`${id}-service`} name="service_needed" required data-event-select="service_selected" aria-describedby={`${id}-service-err`}>
        <option value="">Select a service</option>
        {SERVICES_NEEDED.map((o) => (
          <option value={o} selected={o === defaultService}>{o}</option>
        ))}
      </select>
      <p class="field-error" id={`${id}-service-err`}>Please select the service needed.</p>
    </div>

    <div class="form-field">
      <label for={`${id}-situation`}>Current Water Situation <span class="required-mark" aria-hidden="true">*</span></label>
      <select id={`${id}-situation`} name="water_situation" required data-event-select="water_situation_selected" aria-describedby={`${id}-situation-err`}>
        <option value="">What's going on?</option>
        {WATER_SITUATIONS.map((o) => (
          <option value={o}>{o}</option>
        ))}
      </select>
      <p class="field-error" id={`${id}-situation-err`}>Please describe the current water situation.</p>
    </div>

    {isFull && (
      <>
        <div class="form-field">
          <label for={`${id}-started`}>When the Problem Started <span class="required-mark" aria-hidden="true">*</span></label>
          <select id={`${id}-started`} name="problem_started" required aria-describedby={`${id}-started-err`}>
            <option value="">Select one</option>
            {PROBLEM_STARTED.map((o) => (
              <option value={o}>{o}</option>
            ))}
          </select>
          <p class="field-error" id={`${id}-started-err`}>Please select when the problem started.</p>
        </div>

        <div class="form-field">
          <label for={`${id}-urgency`}>Urgency <span class="required-mark" aria-hidden="true">*</span></label>
          <select id={`${id}-urgency`} name="urgency" required data-event-select="urgency_selected" aria-describedby={`${id}-urgency-err`}>
            <option value="">Select urgency</option>
            {URGENCY_LEVELS.map((o) => (
              <option value={o}>{o}</option>
            ))}
          </select>
          <p class="field-error" id={`${id}-urgency-err`}>Please select an urgency level.</p>
        </div>

        <div class="form-field">
          <label for={`${id}-contact-time`}>Preferred Contact Time <span class="required-mark" aria-hidden="true">*</span></label>
          <select id={`${id}-contact-time`} name="preferred_contact_time" required aria-describedby={`${id}-contact-time-err`}>
            <option value="">Select a time</option>
            {CONTACT_TIMES.map((o) => (
              <option value={o}>{o}</option>
            ))}
          </select>
          <p class="field-error" id={`${id}-contact-time-err`}>Please select a preferred contact time.</p>
        </div>
      </>
    )}

    <div class="form-field">
      <label for={`${id}-details`}>
        {isFull ? "Problem Description" : "What's Going On?"}
        <span class="required-mark" aria-hidden="true">*</span>
      </label>
      <textarea
        id={`${id}-details`}
        name="additional_details"
        required
        maxlength="4000"
        placeholder="Tell us about your water issue…"
        aria-describedby={`${id}-details-err`}></textarea>
      <p class="field-error" id={`${id}-details-err`}>Please describe the problem briefly.</p>
    </div>

    {isFull && (
      <details class="optional-details">
        <summary>Optional system details (helps the provider prepare)</summary>
        <div class="optional-details__body">
          <div class="form-field">
            <label for={`${id}-location`}>Property Address or Nearest Road</label>
            <input type="text" id={`${id}-location`} name="property_location" maxlength="200" />
          </div>
          <div class="form-field">
            <label for={`${id}-pump-type`}>Pump Type</label>
            <select id={`${id}-pump-type`} name="pump_type">
              <option value="">Select if known</option>
              {PUMP_TYPES.map((o) => (
                <option value={o}>{o}</option>
              ))}
            </select>
          </div>
          <div class="form-field">
            <label for={`${id}-well-type`}>Well Type</label>
            <input type="text" id={`${id}-well-type`} name="well_type" maxlength="120" placeholder="e.g., drilled, bored, unknown" />
          </div>
          <div class="form-field">
            <label for={`${id}-depth`}>Approximate Well Depth</label>
            <input type="text" id={`${id}-depth`} name="well_depth" maxlength="60" placeholder="e.g., 250 ft, unknown" />
          </div>
          <div class="form-field">
            <label for={`${id}-pressure`}>Pressure Gauge Reading (if visible)</label>
            <input type="text" id={`${id}-pressure`} name="pressure_reading" maxlength="60" placeholder="e.g., 0 PSI, 40 PSI, unknown" />
          </div>
          <div class="form-field">
            <label for={`${id}-pump-running`}>Can the Pump Be Heard Running?</label>
            <select id={`${id}-pump-running`} name="pump_running">
              <option value="">Select if known</option>
              {PUMP_RUNNING.map((o) => (
                <option value={o}>{o}</option>
              ))}
            </select>
          </div>
          <div class="form-field">
            <label for={`${id}-breaker`}>Breaker Status</label>
            <select id={`${id}-breaker`} name="breaker_status">
              <option value="">Select if known</option>
              {BREAKER_STATUS.map((o) => (
                <option value={o}>{o}</option>
              ))}
            </select>
            <p class="fine-print" style="margin-top:0.3rem;">
              Only report what you can see. Do not open electrical panels or handle wiring.
            </p>
          </div>
          <div class="form-field">
            <label for={`${id}-tank`}>Pressure-Tank Symptoms</label>
            <input type="text" id={`${id}-tank`} name="tank_symptoms" maxlength="300" placeholder="e.g., rapid clicking, tank feels heavy" />
          </div>
          <div class="form-field">
            <label for={`${id}-quality`}>Water-Quality Changes</label>
            <input type="text" id={`${id}-quality`} name="water_quality_changes" maxlength="300" placeholder="e.g., sediment, odor, staining" />
          </div>
          <div class="form-field">
            <label for={`${id}-records`}>Existing Provider or System Records</label>
            <input type="text" id={`${id}-records`} name="system_records" maxlength="300" placeholder="e.g., well log available, installed 2015" />
          </div>
          <div class="form-field">
            <label for={`${id}-photos`}>Photos (optional — JPG, PNG or HEIC, up to 4)</label>
            <input
              type="file"
              id={`${id}-photos`}
              name="photos"
              multiple
              accept=".jpg,.jpeg,.png,.heic,image/jpeg,image/png,image/heic"
              data-event-change="photo_upload"
            />
            <p class="fine-print" style="margin-top:0.3rem;">
              Helpful: well head, pressure tank, gauge, control box exterior, visible leaks or
              equipment labels. Please do not photograph inside electrical panels.
            </p>
          </div>
        </div>
      </details>
    )}

    <div class="consent-row">
      <input type="checkbox" id={`${id}-consent`} name="consent" value="yes" required aria-describedby={`${id}-consent-err`} />
      <label for={`${id}-consent`}>{CONSENT_TEXT}</label>
    </div>
    <p class="field-error" id={`${id}-consent-err`} data-consent-error>Please check the consent box to send your request.</p>

    <div class="cf-turnstile" data-sitekey={SITE.turnstileSiteKey} data-turnstile></div>

    <input type="hidden" name="source_page" value={Astro.url.pathname} />
    <input type="text" name="company_website" value="" tabindex="-1" autocomplete="off" aria-hidden="true" class="hp-field" />

    <button type="submit" class="btn btn--green btn--block" data-submit-btn>
      {isFull ? "Send Well-Service Request" : "Send Service Request"}
    </button>

    <p class="fine-print" style="margin-top:0.8rem;">
      Your request may be shared with an independent local well-service provider. Submission does
      not guarantee availability or response time.
    </p>
    {isFull && <p class="fine-print">{FORM_DISCLAIMER}</p>}
  </form>
</div>

<style>
  .lead-form-card {
    background: var(--white);
    border-radius: var(--radius);
    box-shadow: var(--shadow-raised);
    padding: 1.6rem;
    border-top: 6px solid var(--blue);
  }
  .lead-form-card--hero {
    max-width: 420px;
    width: 100%;
  }
  .lead-form-card__heading {
    font-size: 1.45rem;
    text-transform: uppercase;
    margin-bottom: 0.2rem;
  }
  .lead-form-card__desc {
    font-size: 0.92rem;
    color: #4a5a68;
    margin-bottom: 1.1rem;
  }
  .optional-details {
    border: 1px dashed var(--gray-border);
    border-radius: var(--radius-sm);
    padding: 0.4rem 0.9rem;
    margin-block: 1rem;
  }
  .optional-details summary {
    cursor: pointer;
    font-weight: 600;
    color: var(--blue);
    padding-block: 0.5rem;
  }
  .optional-details__body {
    padding-top: 0.75rem;
  }
  .hp-field {
    position: absolute !important;
    left: -9999px !important;
    width: 1px;
    height: 1px;
    opacity: 0;
  }
  [data-consent-error] {
    display: none;
    color: var(--red-urgent);
    font-size: 0.85rem;
    margin: -0.5rem 0 0.75rem;
  }
  [data-consent-error].is-visible {
    display: block;
  }
  .cf-turnstile {
    margin-block: 0.75rem;
    min-height: 65px;
  }
</style>
