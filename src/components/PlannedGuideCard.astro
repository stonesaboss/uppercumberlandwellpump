---
/**
 * Planned-guide card. Published guides with a real route render as links;
 * unpublished guides render as intentional, non-clickable cards with a
 * subtle "Coming Soon" label — no empty anchors, no href="#", no fake URLs.
 */
import type { PlannedGuide } from "../data/resources";

interface Props {
  guide: PlannedGuide;
}
const { guide } = Astro.props;
const isPublished = guide.status === "published" && !!guide.href;
---

{
  isPublished ? (
    <a class="planned-guide planned-guide--published" href={guide.href}>
      <span class="planned-guide__title">{guide.title}</span>
      {guide.description && <span class="planned-guide__desc">{guide.description}</span>}
    </a>
  ) : (
    <div class="planned-guide">
      <span class="planned-guide__title">{guide.title}</span>
      {guide.description && <span class="planned-guide__desc">{guide.description}</span>}
      <span class="planned-guide__badge">Coming Soon</span>
    </div>
  )
}

<style>
  .planned-guide {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    background: var(--white);
    border: 1px solid var(--gray-border);
    border-radius: var(--radius-sm);
    padding: 1rem 1.1rem;
    height: 100%;
  }
  .planned-guide__title {
    font-weight: 600;
    color: var(--navy);
    line-height: 1.35;
  }
  .planned-guide__desc {
    font-size: 0.9rem;
    color: #4a5a68;
  }
  .planned-guide__badge {
    align-self: flex-start;
    margin-top: auto;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--blue);
    background: var(--blue-light);
    border-radius: 999px;
    padding: 0.2rem 0.65rem;
  }
  a.planned-guide {
    text-decoration: none;
    transition:
      border-color 0.15s ease,
      box-shadow 0.15s ease;
  }
  a.planned-guide:hover {
    border-color: var(--blue);
    box-shadow: var(--shadow-card);
  }
  a.planned-guide .planned-guide__title {
    color: var(--blue);
  }
</style>
