---
/**
 * Category card for the main Resources page — same visual language as the
 * homepage service cards (icon circle, heading, copy, descriptive link).
 */
import Icon from "./Icon.astro";

interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
  linkText?: string;
}
const { title, description, href, icon, linkText } = Astro.props;
---

<div class="card resource-category-card">
  <span class="icon-circle">
    <Icon name={icon} />
  </span>
  <h3><a href={href}>{title}</a></h3>
  <p>{description}</p>
  <a href={href} class="card-link">{linkText ?? title}</a>
</div>

<style>
  .resource-category-card h3 {
    margin-bottom: 0.4rem;
  }
  .resource-category-card h3 a {
    color: var(--navy);
    text-decoration: none;
  }
  .resource-category-card h3 a:hover {
    color: var(--blue);
    text-decoration: underline;
  }
</style>
