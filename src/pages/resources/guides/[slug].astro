---
/**
 * Knowledge-catalog guide pages — one template driven entirely by
 * src/data/guides.ts. Mirrors the resource-hub template so guides match the
 * site exactly. Each guide's slug is referenced as a published href on the
 * matching hub plannedGuide in resources.ts.
 */
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ResourcePageHeader from "../../../components/ResourcePageHeader.astro";
import FaqList from "../../../components/FaqList.astro";
import HelpfulGuides from "../../../components/HelpfulGuides.astro";
import RelatedResources from "../../../components/RelatedResources.astro";
import CtaBand from "../../../components/CtaBand.astro";
import { GUIDES, type Guide } from "../../../data/guides";
import { REFERRAL_DISCLOSURE } from "../../../data/site";
import { webPageSchema, breadcrumbSchema, faqSchema } from "../../../utils/schema";
import { SITE } from "../../../data/site";

export function getStaticPaths() {
  return GUIDES.map((guide) => ({ params: { slug: guide.slug }, props: { guide } }));
}

interface Props {
  guide: Guide;
}
const { guide } = Astro.props;
const route = `/resources/guides/${guide.slug}/`;

const crumbs = [
  { name: "Home", path: "/" },
  { name: "Well Pump Resources", path: "/resources/" },
  { name: guide.hubLabel, path: `/resources/${guide.hub}/` },
  { name: guide.breadcrumbLabel, path: route },
];

const articleSchema = {
  "@type": "Article",
  "@id": new URL(route, SITE.url).href + "#article",
  headline: guide.h1,
  description: guide.metaDescription,
  datePublished: guide.datePublished,
  dateModified: guide.datePublished,
  author: { "@type": "Organization", name: SITE.name },
  mainEntityOfPage: new URL(route, SITE.url).href,
};

const schema = [
  webPageSchema({ path: route, title: guide.title, description: guide.metaDescription }),
  breadcrumbSchema(crumbs),
  articleSchema,
  ...(guide.faqs.length ? [faqSchema(guide.faqs)] : []),
];
---

<BaseLayout title={guide.title} description={guide.metaDescription} path={route} schema={schema}>
  <ResourcePageHeader h1={guide.h1} eyebrow={guide.eyebrow} crumbs={crumbs} intro={guide.intro} image={guide.image} />

  <div class="container guide-body">
    {
      guide.sections.map((section) => (
        <section>
          <h2>{section.heading}</h2>
          {section.paragraphs?.map((p) => <p>{p}</p>)}
          {section.bullets && (
            <ul>
              {section.bullets.map((b) => (
                <li>{b}</li>
              ))}
            </ul>
          )}
        </section>
      ))
    }

    <section aria-labelledby="guide-services-heading">
      <h2 id="guide-services-heading">Related Well Pump Services</h2>
      <ul class="guide-service-links">
        {
          guide.relatedServices.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))
        }
      </ul>
    </section>

    {guide.guideLinks && guide.guideLinks.length > 0 && <HelpfulGuides links={guide.guideLinks} />}

    <RelatedResources hubSlugs={guide.relatedHubs} />

    <div class="disclosure-box">
      <p style="margin:0;">{REFERRAL_DISCLOSURE}</p>
    </div>
  </div>

  {
    guide.faqs.length > 0 && (
      <div class="container guide-body">
        <h2>{`${guide.hubLabel} — Questions`}</h2>
        <FaqList faqs={guide.faqs} />
      </div>
    )
  }

  <CtaBand
    heading="Need Help With a Well Pump Problem?"
    copy="Send the property location, a description of the problem, any recent changes in pressure or water flow, the location of the well head and several clear photographs of the visible system components for an initial service review."
    primaryLabel="Request Well Pump Service"
  />
</BaseLayout>

<style>
  .guide-body {
    max-width: 860px;
    padding-bottom: 1rem;
  }
  .guide-body h2 {
    font-size: clamp(1.4rem, 3vw, 1.8rem);
    margin-top: 2.25rem;
  }
  .guide-body :global(ul) {
    padding-left: 1.4rem;
  }
  .guide-body :global(li) {
    margin-bottom: 0.5rem;
  }
  .guide-service-links {
    padding-left: 1.4rem;
  }
  .guide-service-links li {
    margin-bottom: 0.45rem;
  }
</style>
